# SPDX-License-Identifier: MIT

# Enable MPU
CONFIG_ARM_MPU=y

# Enable GPIO
CONFIG_GPIO=y

# Enable pinctrl
CONFIG_PINCTRL=y

# Enable UART
CONFIG_SERIAL=y
CONFIG_UART_ASYNC_API=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable USB
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_DEVICE_MANUFACTURER="ZMK"
CONFIG_USB_DEVICE_PRODUCT="nice!nano v2 Clear BT"
CONFIG_USB_DEVICE_VID=0x239A
CONFIG_USB_DEVICE_PID=0x000B
CONFIG_USB_CDC_ACM=y

# Enable UF2 build
CONFIG_BUILD_OUTPUT_UF2=y

# Code partition
CONFIG_USE_DT_CODE_PARTITION=y
